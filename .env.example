# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
API_PREFIX=api

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# TESTING: Use defaults (docker-compose starts PostgreSQL at localhost:5432)
# PRODUCTION: Update to managed service hostname and use secrets management

# Full connection string (optional; overrides individual DB_* parameters if set)
DATABASE_URL=postgresql+asyncpg://alpr_user:alpr_password@localhost:5432/alpr

# Individual database parameters (used if DATABASE_URL not set)
DB_HOST=localhost                  # PRODUCTION: Change to RDS/Cloud SQL hostname
DB_PORT=5432
DB_NAME=alpr
DB_USER=alpr_user                  # PRODUCTION: Use Secrets Manager (AWS, GCP, etc.)
DB_PASSWORD=alpr_password          # PRODUCTION: Use Secrets Manager (AWS, GCP, etc.)

# ─── Models ───────────────────────────────────────────────────────────────────
# Directory where InsightFace buffalo_s model will be cached (auto-downloaded)
MODELS_DIR=data/models

# ─── Upload limits ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─── Authentication ───────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the X-Api-Key header.
# Leave empty to disable authentication entirely.
# PRODUCTION: Use strong random keys (e.g., 'openssl rand -hex 32')
API_KEYS=

# ─── Data Retention ───────────────────────────────────────────────────────────
# Days to keep detection events, face events, and alerts. 0 = keep forever.
RETENTION_DAYS=90

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_VEHICLE_DETECTION=true
ENABLE_FACE_DETECTION=true
PERSIST_FACE_EVENTS=true

# ─── Production Settings (Uncomment and configure as needed) ────────────────────
# LOG_LEVEL=INFO                  # PRODUCTION: Use structured logging
# SENTRY_DSN=https://key@sentry.io/project   # PRODUCTION: Error tracking
